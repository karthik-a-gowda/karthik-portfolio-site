---
import type { Profile, SocialLinks, ResumeConfig } from '../content';

interface Props {
  profile: Profile;
  social: SocialLinks;
  resume: ResumeConfig;
}

const { profile, social, resume } = Astro.props;
---

<section id="hero" class="bg-slate-900 text-white pt-20 pb-24 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto flex flex-col-reverse sm:flex-row items-center gap-10 sm:gap-16">

    <!-- Text content -->
    <div class="flex-1 text-center sm:text-left">
      <p class="text-blue-400 font-semibold text-sm uppercase tracking-widest mb-3">
        Available for opportunities
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-4 tracking-tight leading-tight">
        {profile.name}
      </h1>
      <p class="text-xl sm:text-2xl text-blue-300 font-semibold mb-5">
        {profile.title}
      </p>
      <p class="text-gray-300 text-base sm:text-lg leading-relaxed mb-8 max-w-2xl">
        {profile.tagline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 justify-center sm:justify-start">
        <a
          href={resume.path}
          download={resume.downloadName}
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-900"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download Resume
        </a>
        <a
          href={social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-2 border-blue-400 text-blue-300 hover:bg-blue-400 hover:text-slate-900 active:bg-blue-500 font-semibold px-6 py-3 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-900"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Connect on LinkedIn
        </a>
      </div>

      <!-- Certification badge -->
      <div class="mt-8 flex flex-wrap gap-3 justify-center sm:justify-start">
        <span class="inline-flex items-center gap-1.5 bg-slate-800 border border-slate-700 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">
          <svg class="w-3.5 h-3.5 text-blue-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          CKA Certified
        </span>
        <span class="inline-flex items-center gap-1.5 bg-slate-800 border border-slate-700 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">
          <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          KubeCon 2025 Speaker
        </span>
        <span class="inline-flex items-center gap-1.5 bg-slate-800 border border-slate-700 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">
          <svg class="w-3.5 h-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          10+ Years Experience
        </span>
      </div>
    </div>

    <!-- Profile photo -->
    <div class="flex-shrink-0">
      <div class="relative">
        <div class="w-44 h-44 sm:w-52 sm:h-52 rounded-full bg-blue-500/10 ring-4 ring-blue-500 ring-offset-4 ring-offset-slate-900 overflow-hidden shadow-2xl">
          <img
            src={profile.photo}
            alt={profile.photoAlt}
            width="208"
            height="208"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <!-- Decorative circle -->
        <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center shadow-lg" aria-hidden="true">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
      </div>
    </div>

  </div>
</section>
